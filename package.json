{
  "name": "customer-support-system",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "npm run dev:deps && npm run dev:apps",
    "dev:apps": "concurrently -k -n api,web,admin -c cyan,green,magenta \"npm run start:dev --prefix apps/api\" \"npm run dev --prefix apps/web\" \"npm run dev --prefix apps/admin\"",
    "dev:deps": "docker compose -f infra/docker/docker-compose.yml up -d",
    "dev:stop": "docker compose -f infra/docker/docker-compose.yml down",
    "security:sca": "npm audit --audit-level=high",
    "security:osv": "npx --yes osv-scanner@latest --lockfile=package-lock.json",
    "security:sast": "npx --yes semgrep@latest scan --config p/security-audit --error",
    "security:secrets": "npx --yes @gitleaks/gitleaks@latest detect --source . --verbose --redact --exit-code 1",
    "security:container": "npx --yes trivy@latest fs --scanners vuln,secret,misconfig --severity HIGH,CRITICAL --exit-code 1 .",
    "security:dast:baseline": "docker run --rm -t owasp/zap2docker-stable zap-baseline.py -t \"${ZAP_TARGET_URL}\" -m 5 -r zap-report.html",
    "security:all": "npm run security:sca && npm run security:osv && npm run security:sast && npm run security:secrets && npm run security:container"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}
