generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum TicketStatus {
  submitted
  accepted
  in_progress
  resolved
  closed
}

enum AdminRole {
  agent
  admin
}

enum UserStatus {
  active
  disabled
}

model User {
  id              String        @id @default(uuid()) @db.Uuid
  email           String        @unique @db.VarChar(255)
  passwordHash    String        @map("password_hash")
  name            String?       @db.VarChar(120)
  locale          String        @default("en-US") @db.VarChar(10)
  emailVerifiedAt DateTime?     @map("email_verified_at") @db.Timestamptz(6)
  status          UserStatus    @default(active)
  lastLoginAt     DateTime?     @map("last_login_at") @db.Timestamptz(6)
  createdAt       DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime      @updatedAt @map("updated_at") @db.Timestamptz(6)
  sessions        AuthSession[]

  @@map("users")
}

model AuthSession {
  id               String    @id @default(uuid()) @db.Uuid
  userId           String    @map("user_id") @db.Uuid
  refreshTokenHash String    @map("refresh_token_hash")
  userAgent        String?   @map("user_agent") @db.VarChar(255)
  ip               String?   @db.VarChar(64)
  expiresAt        DateTime  @map("expires_at") @db.Timestamptz(6)
  revokedAt        DateTime? @map("revoked_at") @db.Timestamptz(6)
  createdAt        DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId], map: "idx_auth_sessions_user")
  @@index([expiresAt], map: "idx_auth_sessions_expires_at")
  @@map("auth_sessions")
}

model Product {
  id              String         @id @default(uuid()) @db.Uuid
  sku             String         @unique @db.VarChar(64)
  nameEn          String         @map("name_en") @db.VarChar(255)
  nameZh          String         @map("name_zh") @db.VarChar(255)
  category        String         @db.VarChar(100)
  descriptionEn   String?        @map("description_en")
  descriptionZh   String?        @map("description_zh")
  specsJson       Json?          @map("specs_json")
  policySummaryEn String?        @map("policy_summary_en")
  policySummaryZh String?        @map("policy_summary_zh")
  isActive        Boolean        @default(true) @map("is_active")
  createdAt       DateTime       @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime       @updatedAt @map("updated_at") @db.Timestamptz(6)
  images          ProductImage[]
  tickets         Ticket[]

  @@index([category], map: "idx_products_category")
  @@index([isActive], map: "idx_products_is_active")
  @@map("products")
}

model ProductImage {
  id        String   @id @default(uuid()) @db.Uuid
  productId String   @map("product_id") @db.Uuid
  imageUrl  String   @map("image_url")
  sortOrder Int      @default(0) @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId], map: "idx_product_images_product")
  @@map("product_images")
}

model Ticket {
  id                  String              @id @default(uuid()) @db.Uuid
  ticketNo            String              @unique @map("ticket_no") @db.VarChar(32)
  status              TicketStatus
  issueType           String              @map("issue_type") @db.VarChar(50)
  issueDescription    String              @map("issue_description")
  customerName        String              @map("customer_name") @db.VarChar(120)
  customerEmail       String              @map("customer_email") @db.VarChar(255)
  customerPhone       String?             @map("customer_phone") @db.VarChar(50)
  orderRefNo          String?             @map("order_ref_no") @db.VarChar(100)
  productId           String?             @map("product_id") @db.Uuid
  productNameSnapshot String              @map("product_name_snapshot") @db.VarChar(255)
  latestPublicReply   String?             @map("latest_public_reply")
  lastRepliedAt       DateTime?           @map("last_replied_at") @db.Timestamptz(6)
  createdAt           DateTime            @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt           DateTime            @updatedAt @map("updated_at") @db.Timestamptz(6)
  product             Product?            @relation(fields: [productId], references: [id])
  attachments         TicketAttachment[]
  replies             TicketReply[]
  statusHistory       TicketStatusHistory[]

  @@index([customerEmail, ticketNo], map: "idx_tickets_email_ticket_no")
  @@index([status, updatedAt(sort: Desc)], map: "idx_tickets_status_updated_at")
  @@index([createdAt(sort: Desc)], map: "idx_tickets_created_at")
  @@map("tickets")
}

model TicketAttachment {
  id        String   @id @default(uuid()) @db.Uuid
  ticketId  String   @map("ticket_id") @db.Uuid
  storageKey String  @map("storage_key")
  fileName  String   @map("file_name") @db.VarChar(255)
  mimeType  String   @map("mime_type") @db.VarChar(100)
  sizeBytes BigInt   @map("size_bytes")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  ticket    Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  @@index([ticketId], map: "idx_ticket_attachments_ticket")
  @@map("ticket_attachments")
}

model AdminUser {
  id                   String               @id @default(uuid()) @db.Uuid
  email                String               @unique @db.VarChar(255)
  passwordHash         String               @map("password_hash")
  role                 AdminRole
  isActive             Boolean              @default(true) @map("is_active")
  lastLoginAt          DateTime?            @map("last_login_at") @db.Timestamptz(6)
  createdAt            DateTime             @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt            DateTime             @updatedAt @map("updated_at") @db.Timestamptz(6)
  replies              TicketReply[]
  statusChangeHistory  TicketStatusHistory[]

  @@map("admin_users")
}

model TicketReply {
  id            String    @id @default(uuid()) @db.Uuid
  ticketId      String    @map("ticket_id") @db.Uuid
  authorAdminId String    @map("author_admin_id") @db.Uuid
  isPublic      Boolean   @default(false) @map("is_public")
  content       String
  createdAt     DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  ticket        Ticket    @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  author        AdminUser @relation(fields: [authorAdminId], references: [id])

  @@index([ticketId, createdAt(sort: Desc)], map: "idx_ticket_replies_ticket_created")
  @@index([ticketId, isPublic, createdAt(sort: Desc)], map: "idx_ticket_replies_public")
  @@map("ticket_replies")
}

model TicketStatusHistory {
  id               String       @id @default(uuid()) @db.Uuid
  ticketId         String       @map("ticket_id") @db.Uuid
  fromStatus       TicketStatus? @map("from_status")
  toStatus         TicketStatus  @map("to_status")
  changedByAdminId String?      @map("changed_by_admin_id") @db.Uuid
  comment          String?
  createdAt        DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)
  ticket           Ticket       @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  changedBy        AdminUser?   @relation(fields: [changedByAdminId], references: [id])

  @@index([ticketId, createdAt(sort: Desc)], map: "idx_ticket_status_history_ticket_created")
  @@map("ticket_status_history")
}
