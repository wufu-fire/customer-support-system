NODE_ENV=production
# APP_ENV 用于区分业务环境：local / staging / production 等（可选）
APP_ENV=staging

# Nest 全局前缀，需与前端的 VITE_API_BASE_URL 中路径一致
API_PREFIX=api/v1

# 数据库连接串：按环境分别配置
DATABASE_URL=postgresql://css:css_dev_password@localhost:5432/customer_support?schema=public

# 逗号分隔的允许跨域 Origin（不含路径）
# 示例（本地联调）：
# CORS_ORIGINS=http://localhost:5173,http://localhost:5174
# 示例（生产）：
# CORS_ORIGINS=https://tailcarehub.com,https://admin.tailcarehub.com
CORS_ORIGINS=http://localhost:5173,http://localhost:5174

# 鉴权：JWT 与刷新令牌（必配）
# JWT_SECRET 至少 32 字节随机字符串，可使用 `openssl rand -base64 48` 生成
JWT_SECRET=replace_with_long_random_string
# Access Token 生命周期（支持 s/m/h/d 单位）
JWT_ACCESS_TTL=15m
# Refresh Token 生命周期（HttpOnly Cookie）
REFRESH_TTL=30d
